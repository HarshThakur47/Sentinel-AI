# ============================================================
# Sentinel.AI Backend — Environment Variables
# Copy this file to .env and fill in your keys
# ============================================================

# Server
PORT=5000
NODE_ENV=development

# OpenRouter API (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model IDs (OpenRouter format)
FILTER_AGENT_MODEL=meta-llama/llama-3.1-8b-instruct:free
GENERATOR_AGENT_MODEL=anthropic/claude-sonnet-4-5
EVALUATOR_AGENT_MODEL=google/gemini-pro-1.5

# Pinecone Vector DB (https://app.pinecone.io)
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX_NAME=sentinel-docs
PINECONE_ENVIRONMENT=us-east-1

# Embedding Model via OpenRouter (or OpenAI-compatible endpoint)
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=sk-your-openai-key-here

# CORS — Frontend origin
FRONTEND_URL=http://localhost:5173

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30
